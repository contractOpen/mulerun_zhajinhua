{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Go: Debug Backend",
      "type": "go",
      "request": "launch",
      "mode": "auto",
      "program": "${workspaceFolder}/backend",
      "cwd": "${workspaceFolder}/backend",
      "env": {
        "APP_MODE": "pe",
        "PORT": "8080",
        "DB_PATH": "${workspaceFolder}/backend/zhajinhua.db"
      }
    },
    {
      "name": "Python: Current File",
      "type": "python",
      "request": "launch",
      "program": "${file}",
      "console": "integratedTerminal"
    },
    {
      "name": "Python: 实时输出.py",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/../实时输出.py",
      "console": "integratedTerminal"
    },
    {
      "name": "Hardhat: Test Current Project",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceFolder}/contracts/evm",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "test"
      ],
      "console": "integratedTerminal",
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
